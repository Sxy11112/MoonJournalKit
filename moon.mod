name = "Sxy11112/moonjournalkit"

version = "0.1.0"

readme = "README.mbt.md"

repository = "https://github.com/Sxy11112/MoonJournalKit"

license = "Apache-2.0"

keywords = [
  "write-ahead-log",
  "crash-recovery",
  "journal",
  "crc32c",
  "storage-engine",
]

description = "Deterministic transactional write-ahead log framing and crash recovery for MoonBit."
